// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Int
  image       String?
  stock       Int      @default(0)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String
  value       Int
  minValue    Int?
  expiresAt   DateTime?
  usageLimit  Int?
  usedCount   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  id              String   @id @default(cuid())
  customerEmail   String
  customerName    String?
  status          String   @default("PENDING")
  subtotal        Int
  discount        Int      @default(0)
  shipping        Int      @default(0)
  total           Int
  paymentIntentId String?
  coupon          Coupon?  @relation(fields: [couponId], references: [id])
  couponId        String?
  items           OrderItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  unitPrice Int
}

model OwnerAccessCode {
  id         String   @id @default(cuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([email, expiresAt])
}

model SiteConfig {
  id              String   @id
  heroTitle       String
  heroDescription String
  heroBadge       String   @default("vitrine artesanal + checkout")
  heroPanelTopTitle        String   @default("Jornal da cozinha")
  heroPanelTopDescription  String   @default("Receitas novas, ajustes de preco e fotos atualizadas direto da cozinha da JL.")
  heroPanelBottomTitle     String   @default("Panelinha da JL")
  heroPanelBottomDescription String @default("Dashboard com relatorio de estoque, doces mais pedidos e campanhas de frete gratuito. Tudo pronto para registrar novas delicias.")
  heroPanelFooter          String   @default("Replique cenarios reais de confeitaria sem precisar de Stripe real. Ideal para apresentar jornadas completas e pontos de personalizacao para clientes gulosos.")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
